# グローバル変数（スコープの例）
ADULT_AGE = 20


# クラス定義
class Human:
    def __init__(self, name, age):
        self.name = name
        self.age = age

    # 条件分岐を使ったメソッド
    def check_adult(self):
        if self.age >= ADULT_AGE:
            print(self.name + "さんは大人です")
            return "adult"
        else:
            print(self.name + "さんは大人ではありません")
            return "child"


# 関数（リスト・ディクショナリを使用）
def process_humans(human_list):
    # ディクショナリで分類
    result = {
        "adult": [],
        "child": []
    }

    # 繰り返し処理
    for human in human_list:
        category = human.check_adult()  # メソッド呼び出し

        # ディクショナリに追加
        result[category].append(human.name)

    return result


# メイン処理（関数）
def main():
    # リストにインスタンスを格納
    humans = [
        Human("たくや", 25),
        Human("しずく", 18),
        Human("しゅり", 30),
        Human("のりひろ", 15)
    ]

    # 関数呼び出し
    summary = process_humans(humans)

    print("\n【集計結果】")
    print("大人:", summary["adult"])
    print("子ども:", summary["child"])


# 実行
main()